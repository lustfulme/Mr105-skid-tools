:Network Checker
echo. Loading Network Info...

:cls
rem Get SSID
for /f "tokens=2* delims=:" %%a in ('netsh wlan show interface ^| find "SSID"') do set ssid=%%a
rem Remove leading spaces from SSID
set ssid=%ssid: =%

rem Get Network Adapter Description
for /f "tokens=2* delims=:" %%a in ('netsh wlan show interface ^| find "Description"') do set adapter=%%a
rem Remove leading spaces from Adapter
set adapter=%adapter: =%

rem Get Network State (Connected/Disconnected)
for /f "tokens=2* delims=:" %%a in ('netsh wlan show interface ^| find "State"') do set state=%%a
rem Remove leading spaces from State
set state=%state: =%

rem Get Signal Strength
for /f "tokens=2* delims=:" %%a in ('netsh wlan show interface ^| find "Signal"') do set signal=%%a
rem Remove leading spaces from Signal
set signal=%signal: =%

rem Get Receive Rate (Mbps)
for /f "tokens=2* delims=:" %%a in ('netsh wlan show interface ^| find "Receive rate"') do set recvRate=%%a
rem Remove leading spaces from Receive Rate
set recvRate=%recvRate: =%

rem Get Transmit Rate (Mbps)
for /f "tokens=2* delims=:" %%a in ('netsh wlan show interface ^| find "Transmit rate"') do set transRate=%%a
rem Remove leading spaces from Transmit Rate
set transRate=%transRate: =%

rem Get Ping Statistics (ping to 8.8.8.8)
ping -n 3 8.8.8.8 > %temp%\ping.txt
for /f "tokens=4 delims== " %%a in ('find "Average" %temp%\ping.txt') do set pingAvg=%%a
rem Remove leading spaces from Ping Average
set pingAvg=%pingAvg: =%

rem Display the Network Info
echo.
echo Network Info:
echo ================
echo SSID: %ssid%
echo Adapter: %adapter%
echo State: %state%
echo Signal Strength: %signal%
echo Receive Rate (Mbps): %recvRate%
echo Transmit Rate (Mbps): %transRate%
echo.========================
echo Ping Stats:
echo ===========================
echo Average Ping: %pingAvg%
echo.
pause
goto MENU


:exit
